generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model UserProfile {
  id        String    @id @default(uuid()) @db.Uuid
  clerkId   String    @unique
  email     String    @unique
  fullName  String?
  role      String    @default("qs")
  officeId  String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  office      Office?       @relation(fields: [officeId], references: [id])
  tasks       Task[]        @relation("TaskAssignee")
  attendance  Attendance[]
  queryRaised TaskQueryLog[] @relation("QueryRaisedBy")
  queryReplied TaskQueryLog[] @relation("QueryRespondedBy")
}

model Project {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  code      String   @unique
  officeId  String?  @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  office Office? @relation(fields: [officeId], references: [id])
  tasks  Task[]
}

model Task {
  id              String         @id @default(uuid()) @db.Uuid
  projectId       String         @db.Uuid
  title           String
  description     String?
  status          String         @default("ASSIGNED")
  plannedRate     Float?
  actualRate      Float?
  efficiency      Float?
  variance        Float?
  assigneeId      String?        @db.Uuid
  reviewComment   String?
  reviewOutcome   String?
  submittedAt     DateTime?
  reviewedAt      DateTime?
  revisionCount   Int            @default(0)
  timeSpentMinute Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  project  Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee UserProfile? @relation("TaskAssignee", fields: [assigneeId], references: [id])
  logs     TaskTimeLog[]
  queries  TaskQueryLog[]
}

model TaskTimeLog {
  id        String   @id @default(uuid()) @db.Uuid
  taskId    String   @db.Uuid
  startedAt DateTime
  endedAt   DateTime?
  minutes   Int      @default(0)
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Attendance {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  officeId    String?  @db.Uuid
  workDate    DateTime
  checkInTime DateTime
  status      String
  reason      String?
  confirmed   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  office Office?     @relation(fields: [officeId], references: [id])

  @@unique([userId, workDate])
}

model Office {
  id             String      @id @default(uuid()) @db.Uuid
  code           String      @unique
  name           String
  city           String?
  country        String?
  managingUserId String?     @db.Uuid
  active         Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  users      UserProfile[]
  projects   Project[]
  attendance Attendance[]
}

model TaskQueryLog {
  id            String    @id @default(uuid()) @db.Uuid
  taskId         String    @db.Uuid
  drawingRef     String?
  description    String
  impact         String?
  raisedById     String?   @db.Uuid
  response       String?
  respondedById  String?   @db.Uuid
  respondedAt    DateTime?
  resolved       Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  task         Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  raisedBy     UserProfile? @relation("QueryRaisedBy", fields: [raisedById], references: [id])
  respondedBy  UserProfile? @relation("QueryRespondedBy", fields: [respondedById], references: [id])
}
