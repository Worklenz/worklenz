{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@/worklenz-ee/*": ["worklenz-ce/*"],
      "@/*": ["src/*"],
      "@components/*": ["src/components/*"],
      "@features/*": ["src/features/*"],
      "@assets/*": ["src/assets/*"],
      "@utils/*": ["src/utils/*"],
      "@api/*": ["src/api/*"],
      "@services/*": ["src/services/*"]
    }
  },
  "include": ["src", "worklenz-ce"]
}
